{
  "version": "1.0.0",
  "redactionText": "[***REDACTED***]",
  "patterns": [
    {
      "name": "TenantDomain",
      "pattern": "(-Organization\\s+['\"]?)([a-zA-Z0-9][a-zA-Z0-9-]*\\.onmicrosoft\\.com)(['\"]?)",
      "enabled": true
    },
    {
      "name": "AppID",
      "pattern": "(-AppId\\s+['\"]?)([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12})(['\"]?)",
      "enabled": true
    },
    {
      "name": "CertificateThumbprint",
      "pattern": "(-CertificateThumbprint\\s+['\"]?)([0-9a-fA-F]{40})(['\"]?)",
      "enabled": true
    },
    {
      "name": "LocalUserPath",
      "pattern": "([C-Z]:\\\\Users\\\\)([^\\\\]+)(\\\\)",
      "enabled": true
    },
    {
      "name": "EmailAddress",
      "pattern": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b",
      "enabled": false
    }
  ]
}
